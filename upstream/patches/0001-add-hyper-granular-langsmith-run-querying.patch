diff --git a/README.md b/README.md
index add63ed..bc1f612 100644
--- a/README.md
+++ b/README.md
@@ -133,10 +133,15 @@ langsmith trace list --project my-app --include-metadata   # + status, duration,
 langsmith trace list --project my-app --include-io         # + inputs, outputs, error
 langsmith trace list --project my-app --include-feedback   # + feedback_stats
 langsmith trace list --project my-app --full               # All fields (metadata + io + feedback)
+langsmith trace list --project my-app --include-all        # Raw run JSON + depth/agent_type
 
 # Show trace hierarchy (fetches full run tree for each trace)
 langsmith trace list --project my-app --show-hierarchy --limit 3
 
+# Find traces whose tree contains specific runs
+langsmith trace list --project my-app --tree-filter 'eq(name, "RetrieveDocs")' --trace-filter 'eq(feedback_key, "user_score")'
+langsmith trace list --project my-app --include-all --show-hierarchy --agent-type subagent --min-depth 2
+
 # Get a specific trace
 langsmith trace get <trace-id> --project my-app --full
 
@@ -164,6 +169,11 @@ langsmith run list --project my-app --run-type llm --min-tokens 1000 --include-m
 # Include feedback scores
 langsmith run list --project my-app --include-feedback
 
+# Query a specific depth or arbitrary hydrated JSON path
+langsmith run list --project my-app --include-all --agent-type subagent --min-depth 3 --max-depth 3
+langsmith run list --project my-app --include-all --field extra.metadata.phase=planning
+langsmith run list --project my-app --parent-run-id <run-id>
+
 # Get a specific run
 langsmith run get <run-id> --full
 
@@ -328,9 +338,19 @@ Most `trace` and `run` commands share these filter options:
 | `--max-latency` | Max latency (seconds) | `--max-latency 10` |
 | `--min-tokens` | Min total tokens | `--min-tokens 1000` |
 | `--tags` | Tags (comma-separated, OR logic) | `--tags prod,v2` |
+| `--metadata` | Metadata key or key=value | `--metadata revision_id=abc123` |
+| `--parent-run-id` | Direct children of a parent run | `--parent-run-id <run-id>` |
+| `--trace-filter` | Raw DSL applied to root runs | `--trace-filter 'eq(feedback_key, "score")'` |
+| `--tree-filter` | Raw DSL applied to any run in the trace tree | `--tree-filter 'eq(name, "RetrieveDocs")'` |
+| `--agent-type` | Client-side `extra.metadata.ls_agent_type` filter | `--agent-type subagent` |
+| `--min-depth` | Client-side minimum run depth | `--min-depth 2` |
+| `--max-depth` | Client-side maximum run depth | `--max-depth 4` |
+| `--field` | Client-side `path=value` over hydrated run JSON; repeatable | `--field extra.metadata.phase=plan` |
 | `--filter` | Raw LangSmith filter DSL | `--filter 'eq(status, "error")'` |
 | `--trace-ids` | Specific trace IDs | `--trace-ids abc123,def456` |
 
+Use `--include-all` on `trace` and `run` commands when combining local filters such as `--field`, `--agent-type`, and depth filters with raw run fields. It requests all selectable LangSmith run fields and adds derived `depth`, `agent_type`, and `run_id` alias fields to JSON/JSONL output. On `trace list` and `trace export`, local depth, agent type, and field filters match any run in the trace tree.
+
 ## Local Development
 
 For local dev, create a launcher script at `~/.local/bin/langsmith` that loads your `.env` and uses `go run`:
