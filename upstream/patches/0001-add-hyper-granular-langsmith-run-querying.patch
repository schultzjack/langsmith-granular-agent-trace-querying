+func assertGoldenJSON(t *testing.T, name string, got []byte) {
+	t.Helper()
+	assertGoldenBytes(t, name, normalizeJSON(t, got))
+}
+
+func assertGoldenJSONL(t *testing.T, name string, got []byte) {
+	t.Helper()
+	assertGoldenBytes(t, name, normalizeJSONL(t, got))
+}
+
+func assertGoldenBytes(t *testing.T, name string, got []byte) {
+	t.Helper()
+	path := filepath.Join("testdata", "hyper_granular_e2e", name)
+	if os.Getenv(updateHyperGranularFixturesEnv) != "" {
+		if err := os.MkdirAll(filepath.Dir(path), 0o755); err != nil {
+			t.Fatalf("mkdir fixture dir: %v", err)
+		}
+		if err := os.WriteFile(path, got, 0o644); err != nil {
+			t.Fatalf("write fixture %s: %v", path, err)
+		}
+		return
+	}
+
+	want, err := os.ReadFile(path)
+	if err != nil {
+		t.Fatalf("read fixture %s: %v\nSet %s=1 to regenerate it from the real command path.", path, err, updateHyperGranularFixturesEnv)
+	}
+	if !bytes.Equal(want, got) {
+		t.Fatalf("fixture mismatch for %s\nwant:\n%s\n\ngot:\n%s", path, string(want), string(got))
+	}
+}
+
+func normalizeJSON(t *testing.T, data []byte) []byte {
+	t.Helper()
+	var value any
+	if err := json.Unmarshal(data, &value); err != nil {
+		t.Fatalf("invalid JSON fixture data: %v\n%s", err, string(data))
+	}
+	return mustMarshalIndent(t, value)
+}
+
+func normalizeJSONL(t *testing.T, data []byte) []byte {
+	t.Helper()
+	var out bytes.Buffer
+	scanner := bufio.NewScanner(bytes.NewReader(data))
+	for scanner.Scan() {
+		line := strings.TrimSpace(scanner.Text())
+		if line == "" {
+			continue
+		}
+		normalized := normalizeJSONCompact(t, []byte(line))
+		out.Write(normalized)
+		out.WriteByte('\n')
+	}
+	if err := scanner.Err(); err != nil {
+		t.Fatalf("scan JSONL: %v", err)
+	}
+	return out.Bytes()
+}
+
+func normalizeJSONCompact(t *testing.T, data []byte) []byte {
+	t.Helper()
+	var value any
+	if err := json.Unmarshal(data, &value); err != nil {
+		t.Fatalf("invalid JSONL fixture data: %v\n%s", err, string(data))
+	}
+	out, err := json.Marshal(value)
+	if err != nil {
+		t.Fatalf("marshal compact JSON: %v", err)
+	}
+	return out
+}
+
+func mustMarshalIndent(t *testing.T, value any) []byte {
+	t.Helper()
+	out, err := json.MarshalIndent(value, "", "  ")
+	if err != nil {
+		t.Fatalf("marshal JSON: %v", err)
+	}
+	out = append(out, '\n')
+	return out
+}
