+func queryTraceRoots(ctx context.Context, c *client.Client, params langsmith.RunQueryParams, projectName string, limit int, filters RunLocalFilters) (traceQueryResult, error) {
+	if !hasTraceTreeLocalFilters(filters) {
+		roots, err := queryRuns(ctx, c, params, projectName, limit, filters)
+		return traceQueryResult{Roots: roots}, err
+	}
+
+	if projectName != "" {
+		sessionID, err := c.ResolveSessionID(ctx, projectName)
+		if err != nil {
+			return traceQueryResult{}, err
+		}
+		params.Session = langsmith.F([]string{sessionID})
+	}
+
+	result := traceQueryResult{
+		Roots:       []langsmith.RunSchema{},
+		RunsByTrace: map[string][]langsmith.RunSchema{},
+	}
+	rootFilters := traceRootLocalFilters(filters)
+	treeFilters := traceTreeLocalFilters(filters)
+
+	for {
+		resp, err := c.SDK.Runs.Query(ctx, params)
+		if err != nil {
+			return traceQueryResult{}, fmt.Errorf("querying trace roots: %w", err)
+		}
+
+		for _, root := range resp.Runs {
+			if len(result.Roots) >= limit {
+				return result, nil
+			}
+			if !runMatchesLocalFilters(root, rootFilters) {
+				continue
+			}
+
+			traceRuns, err := queryRunsForTrace(ctx, c, projectName, root.TraceID, buildAllRunSelect())
+			if err != nil {
+				return traceQueryResult{}, err
+			}
+			if !traceTreeMatchesLocalFilters(traceRuns, treeFilters) {
+				continue
+			}
+
+			result.Roots = append(result.Roots, root)
+			result.RunsByTrace[root.TraceID] = traceRuns
+		}
+
+		if resp.Cursors == nil || resp.Cursors["next"] == "" || len(result.Roots) >= limit {
+			break
+		}
+		params.Cursor = langsmith.F(resp.Cursors["next"])
+	}
+
+	return result, nil
+}
+
+func queryRunsForTrace(ctx context.Context, c *client.Client, projectName, traceID string, selectFields []langsmith.RunQueryParamsSelect) ([]langsmith.RunSchema, error) {
+	params := langsmith.RunQueryParams{
+		Trace: langsmith.F(traceID),
+		Order: langsmith.F(langsmith.RunQueryParamsOrderAsc),
+	}
+	if selectFields != nil {
+		params.Select = langsmith.F(selectFields)
+	}
+	return queryRuns(ctx, c, params, projectName, 1000, RunLocalFilters{})
+}
+
+func localFiltersFromFlags(f *FilterFlags) RunLocalFilters {
+	return RunLocalFilters{
+		MinTokens:    f.MinTokens,
+		MinDepth:     f.MinDepth,
+		MaxDepth:     f.MaxDepth,
+		AgentType:    f.AgentType,
+		FieldFilters: f.FieldFilters,
+	}
+}
+
+func hasTraceTreeLocalFilters(filters RunLocalFilters) bool {
+	return filters.MinDepth > 0 || filters.MaxDepth > 0 || filters.AgentType != "" || len(filters.FieldFilters) > 0
+}
+
+func traceRootLocalFilters(filters RunLocalFilters) RunLocalFilters {
+	return RunLocalFilters{
+		MinTokens: filters.MinTokens,
+	}
+}
+
+func traceTreeLocalFilters(filters RunLocalFilters) RunLocalFilters {
+	return RunLocalFilters{
+		MinDepth:     filters.MinDepth,
+		MaxDepth:     filters.MaxDepth,
+		AgentType:    filters.AgentType,
+		FieldFilters: filters.FieldFilters,
+	}
+}
+
+func traceTreeMatchesLocalFilters(runs []langsmith.RunSchema, filters RunLocalFilters) bool {
+	for _, run := range runs {
+		if runMatchesLocalFilters(run, filters) {
+			return true
+		}
+	}
+	return false
+}
+
+func runMatchesLocalFilters(run langsmith.RunSchema, filters RunLocalFilters) bool {
+	if filters.MinTokens > 0 && run.TotalTokens < int64(filters.MinTokens) {
+		return false
+	}
+	depth := extract.RunDepth(run)
+	if filters.MinDepth > 0 && depth < filters.MinDepth {
+		return false
+	}
+	if filters.MaxDepth > 0 && depth > filters.MaxDepth {
+		return false
+	}
+	if filters.AgentType != "" && extract.AgentType(run) != filters.AgentType {
+		return false
+	}
+	for _, fieldFilter := range filters.FieldFilters {
+		if !runMatchesFieldFilter(run, fieldFilter) {
+			return false
+		}
+	}
+	return true
+}
+
+func runMatchesFieldFilter(run langsmith.RunSchema, filter string) bool {
+	path, want, ok := strings.Cut(filter, "=")
+	if !ok {
+		return false
+	}
+	path = strings.TrimSpace(path)
+	want = strings.TrimSpace(want)
+	if path == "" {
+		return false
+	}
+
+	data := runToMap(run)
+	got, ok := valueAtPath(data, path)
+	if !ok {
+		return false
+	}
+	return fmt.Sprint(got) == want
+}
+
+func runToMap(run langsmith.RunSchema) map[string]any {
+	b, err := json.Marshal(run)
+	if err != nil {
+		return map[string]any{}
+	}
+	var data map[string]any
+	if err := json.Unmarshal(b, &data); err != nil {
+		return map[string]any{}
+	}
+	data["run_id"] = run.ID
+	data["depth"] = extract.RunDepth(run)
+	if agentType := extract.AgentType(run); agentType != "" {
+		data["agent_type"] = agentType
+	}
+	return data
+}
+
+func valueAtPath(data map[string]any, path string) (any, bool) {
+	var cur any = data
+	for _, part := range strings.Split(path, ".") {
+		switch typed := cur.(type) {
+		case map[string]any:
+			next, ok := typed[part]
+			if !ok {
+				return nil, false
+			}
+			cur = next
+		case []any:
+			idx, err := strconv.Atoi(part)
+			if err != nil || idx < 0 || idx >= len(typed) {
+				return nil, false
+			}
+			cur = typed[idx]
+		default:
+			return nil, false
+		}
+	}
+	return cur, true
+}
