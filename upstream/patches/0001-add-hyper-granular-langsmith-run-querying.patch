+// ExtractRunFull returns the complete RunSchema as JSON-compatible data, plus
+// derived hierarchy fields used for granular trace analysis.
+func ExtractRunFull(run langsmith.RunSchema) map[string]any {
+	var result map[string]any
+	b, err := json.Marshal(run)
+	if err == nil {
+		_ = json.Unmarshal(b, &result)
+	}
+	if result == nil {
+		result = map[string]any{}
+	}
+
+	result["run_id"] = run.ID
+	result["depth"] = RunDepth(run)
+	if agentType := AgentType(run); agentType != "" {
+		result["agent_type"] = agentType
+	}
+	return result
+}
+
+// RunDepth returns the zero-based depth of a run in its trace tree.
+func RunDepth(run langsmith.RunSchema) int {
+	if len(run.ParentRunIDs) > 0 {
+		return len(run.ParentRunIDs)
+	}
+	if run.DottedOrder != "" {
+		return strings.Count(run.DottedOrder, ".")
+	}
+	if run.ParentRunID != "" {
+		return 1
+	}
+	return 0
+}
+
+// AgentType returns LangSmith's agent-type metadata when present.
+func AgentType(run langsmith.RunSchema) string {
+	if run.Extra == nil {
+		return ""
+	}
+	metadata, ok := run.Extra["metadata"].(map[string]any)
+	if !ok {
+		return ""
+	}
+	value, ok := metadata["ls_agent_type"].(string)
+	if !ok {
+		return ""
+	}
+	return value
+}
