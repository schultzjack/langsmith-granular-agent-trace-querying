+
+func hyperGranularRun(id, traceID, name, runType, parentID string, parentIDs []string, startTime string, metadata map[string]any) map[string]any {
+	endTime := strings.Replace(startTime, "Z", ".250Z", 1)
+	run := map[string]any{
+		"id":             id,
+		"trace_id":       traceID,
+		"name":           name,
+		"run_type":       runType,
+		"session_id":     "session-123",
+		"status":         "success",
+		"start_time":     startTime,
+		"end_time":       endTime,
+		"dotted_order":   dottedOrder(parentIDs, id),
+		"parent_run_ids": parentIDs,
+		"child_run_ids":  []string{},
+		"tags":           []string{"fixture", "agent-trace"},
+		"extra":          map[string]any{"metadata": metadata},
+		"inputs": map[string]any{
+			"messages": []any{map[string]any{"role": "user", "content": "Find trace query options"}},
+		},
+		"outputs": map[string]any{
+			"result": fmt.Sprintf("%s complete", name),
+		},
+		"events": []map[string]any{{"name": "start", "time": startTime}},
+	}
+	if parentID != "" {
+		run["parent_run_id"] = parentID
+	}
+	switch id {
+	case "planner-keep":
+		run["total_tokens"] = 1750
+		run["prompt_tokens"] = 1200
+		run["completion_tokens"] = 550
+		run["total_cost"] = "0.0123"
+	case "retriever-keep":
+		run["total_tokens"] = 250
+	default:
+		run["total_tokens"] = 900
+	}
+	return run
+}
+
+func dottedOrder(parentIDs []string, id string) string {
+	parts := append([]string{}, parentIDs...)
+	parts = append(parts, id)
+	return strings.Join(parts, ".")
+}
+
+func normalizeTraceExportStdout(t *testing.T, data []byte) []byte {
+	t.Helper()
+	var result map[string]any
+	if err := json.Unmarshal(data, &result); err != nil {
+		t.Fatalf("trace export stdout is not JSON: %v\n%s", err, string(data))
+	}
+	result["output_dir"] = "<tmp>"
+	return mustMarshalIndent(t, result)
+}
